#!/usr/bin/env bash
# SessionStart hook for the plan-staged-rollout plugin.
#
# If the current repo has a staged rollout in progress (a .plan/ directory at
# the repo root), inject a short context nudge naming the next runnable stage
# so a fresh session surfaces the rollout without the user having to remember
# the namespaced /plan-staged-rollout:plan-run command. The nudge only OFFERS —
# execution is still governed by the operating protocol in .plan/PLAN.md.
#
# Hard constraint: FAIL SILENT. This hook runs in every session in the repo,
# so on malformed .plan/ files or any parse ambiguity it must emit nothing and
# exit 0 — never error, never block a session. In the common case (no .plan/)
# it emits nothing at essentially zero cost.

# Nothing this script could write to stderr is worth risking a session over.
exec 2>/dev/null

trim() {
    local s="$1"
    s="${s#"${s%%[![:space:]]*}"}"
    s="${s%"${s##*[![:space:]]}"}"
    printf '%s' "$s"
}

# Escape string for JSON embedding using bash parameter substitution.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

# Parsed LEDGER.md status-table rows (parallel arrays).
ledger_ids=()
ledger_names=()
ledger_statuses=()

# Parsed PLAN.md stage-index rows (parallel arrays).
index_ids=()
index_depends=()
index_models=()
index_efforts=()

# Split a markdown table row into the global `cells` array.
# Fails on non-table lines; separator/header rows are rejected later by
# stage_id_of.
cells=()
split_row() {
    local line="$1"
    case "$line" in
        \|*) ;;
        *) return 1 ;;
    esac
    local body="${line#|}"
    body="${body%|}"
    local IFS='|'
    read -ra cells <<< "$body"
    [ "${#cells[@]}" -ge 2 ]
}

# Print the stage id (S<digits> or SF) leading a stage cell; fail otherwise.
stage_id_of() {
    local c id
    c="$(trim "$1")"
    id="${c%%[[:space:]]*}"
    case "$id" in
        S[0-9]|S[0-9][0-9]|SF) printf '%s' "$id" ;;
        *) return 1 ;;
    esac
}

# Parse the "## Status" table of LEDGER.md. Unrecognized rows and statuses
# outside the todo/doing/done/blocked/skipped vocabulary are skipped, not
# errors.
parse_ledger() {
    local in_section=0 line id name status
    while IFS= read -r line || [ -n "$line" ]; do
        case "$line" in
            '## Status'*) in_section=1; continue ;;
            '## '*) if [ "$in_section" -eq 1 ]; then break; fi ;;
        esac
        [ "$in_section" -eq 1 ] || continue
        split_row "$line" || continue
        id="$(stage_id_of "${cells[0]}")" || continue
        name="$(trim "${cells[0]}")"
        name="$(trim "${name#"$id"}")"
        status="$(trim "${cells[1]}" | tr '[:upper:]' '[:lower:]')"
        case "$status" in
            todo|doing|done|blocked|skipped) ;;
            *) continue ;;
        esac
        ledger_ids+=("$id")
        ledger_names+=("$name")
        ledger_statuses+=("$status")
    done < "$1"
}

# Parse the "## Stage index" table of PLAN.md
# (| Stage | File | Depends | mode | exec | model | effort |).
parse_index() {
    local in_section=0 line id
    while IFS= read -r line || [ -n "$line" ]; do
        case "$line" in
            '## Stage index'*) in_section=1; continue ;;
            '## '*) if [ "$in_section" -eq 1 ]; then break; fi ;;
        esac
        [ "$in_section" -eq 1 ] || continue
        split_row "$line" || continue
        id="$(stage_id_of "${cells[0]}")" || continue
        [ "${#cells[@]}" -ge 3 ] || continue
        index_ids+=("$id")
        index_depends+=("$(trim "${cells[2]}")")
        index_models+=("$(trim "${cells[5]:-}")")
        index_efforts+=("$(trim "${cells[6]:-}")")
    done < "$1"
}

# Print the ledger status of a stage id; fail if the id has no ledger row.
status_of() {
    local id="$1" j
    for j in "${!ledger_ids[@]}"; do
        if [ "${ledger_ids[$j]}" = "$id" ]; then
            printf '%s' "${ledger_statuses[$j]}"
            return 0
        fi
    done
    return 1
}

# Print the stage-index array position of a stage id; fail if not indexed.
index_pos_of() {
    local id="$1" j
    for j in "${!index_ids[@]}"; do
        if [ "${index_ids[$j]}" = "$id" ]; then
            printf '%s' "$j"
            return 0
        fi
    done
    return 1
}

# A Depends cell is satisfied when empty/"—" or every listed stage id is
# `done` in the ledger. Anything unrecognized counts as NOT satisfied — the
# nudge must never claim a stage is runnable on a guess.
deps_satisfied() {
    local deps d dep_status
    deps="$(trim "${1//,/ }")"
    case "$deps" in
        ''|'—'|'-'|'–') return 0 ;;
    esac
    for d in $deps; do
        case "$d" in
            S[0-9]|S[0-9][0-9]|SF) ;;
            *) return 1 ;;
        esac
        dep_status="$(status_of "$d")" || return 1
        [ "$dep_status" = "done" ] || return 1
    done
    return 0
}

main() {
    local root
    root="$(git rev-parse --show-toplevel 2>/dev/null)"
    [ -n "$root" ] || root="$PWD"
    local plan_dir="$root/.plan"
    # No .plan/ — the common case in every non-rollout repo: emit nothing.
    [ -d "$plan_dir" ] || return 0
    [ -f "$plan_dir/LEDGER.md" ] || return 0
    [ -f "$plan_dir/PLAN.md" ] || return 0

    parse_ledger "$plan_dir/LEDGER.md" || return 0
    parse_index "$plan_dir/PLAN.md" || return 0
    [ "${#ledger_ids[@]}" -gt 0 ] || return 0

    # Next runnable stage: a `doing` stage to resume, else the first `todo`
    # whose depends (read from the PLAN.md stage index — a stage missing from
    # that index is invisible to this logic, per PLAN.md) are all `done`.
    local next=-1 resume=0 i pos
    for i in "${!ledger_ids[@]}"; do
        if [ "${ledger_statuses[$i]}" = "doing" ]; then
            next=$i
            resume=1
            break
        fi
    done
    if [ "$next" -lt 0 ]; then
        for i in "${!ledger_ids[@]}"; do
            [ "${ledger_statuses[$i]}" = "todo" ] || continue
            pos="$(index_pos_of "${ledger_ids[$i]}")" || continue
            deps_satisfied "${index_depends[$pos]}" || continue
            next=$i
            break
        done
    fi

    local context
    if [ "$next" -ge 0 ]; then
        local id="${ledger_ids[$next]}" name="${ledger_names[$next]}"
        local num model="" effort="" weight="" action
        num="$(printf '%s' "${id#S}" | tr '[:upper:]' '[:lower:]')"
        if pos="$(index_pos_of "$id")"; then
            model="${index_models[$pos]}"
            effort="${index_efforts[$pos]}"
        fi
        case "$model" in ''|'—'|'-') ;; *) weight="model \`$model\`" ;; esac
        case "$effort" in ''|'—'|'-') ;; *) weight="${weight:+$weight, }effort \`$effort\`" ;; esac
        [ -n "$weight" ] && weight=" Recommended launch: $weight."
        action="run"
        [ "$resume" -eq 1 ] && action="resume (it is \`doing\` — a session left it partially complete)"
        context="**Active staged rollout in this repo** (\`.plan/\` present). Next runnable stage: **$id${name:+ — $name}**, to $action.$weight

Offer to continue it via the plan-run command for stage $num — \`/plan-staged-rollout:plan-run $num\` — but do NOT auto-run it: surface this to the user and wait for their go-ahead. The weight check, dependency gate, and operating protocol in \`.plan/PLAN.md\` still govern execution."
    else
        local open=0 st
        for st in "${ledger_statuses[@]}"; do
            case "$st" in
                done|skipped) ;;
                *) open=1 ;;
            esac
        done
        if [ "$open" -eq 0 ]; then
            context="**Active staged rollout in this repo** (\`.plan/\` present) — every stage is \`done\` or \`skipped\`, so the plan is ready for closeout. Offer to close it out via \`/plan-staged-rollout:plan-close\`, but do NOT auto-run it: surface this to the user and wait for their go-ahead."
        else
            context="**Active staged rollout in this repo** (\`.plan/\` present), but no stage is currently runnable — the remaining stages are \`blocked\` or waiting on unmet dependencies. Surface this to the user and point them at \`.plan/LEDGER.md\` for the details. Do not run any stage."
        fi
    fi

    local escaped
    escaped="$(escape_for_json "$context")"

    # Output context injection as JSON.
    # Cursor hooks expect additional_context (snake_case).
    # Claude Code hooks expect hookSpecificOutput.additionalContext (nested).
    # Copilot CLI (v1.0.11+) and others expect additionalContext (top-level,
    # SDK standard). Claude Code reads BOTH additional_context and
    # hookSpecificOutput without deduplication, so emit only the field the
    # current platform consumes.
    if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
        printf '{\n  "additional_context": "%s"\n}\n' "$escaped"
    elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
        printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$escaped"
    else
        printf '{\n  "additionalContext": "%s"\n}\n' "$escaped"
    fi
}

main
exit 0
